{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CinemaGrafik",
  "version": "0.1.3",
  "identifier": "com.cinemagrafik.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cinema Grafik",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "plugins": {
      "updater": {
        "endpoints": [
          "https://github.com/sukehama/cinemagrafik/releases/latest/download/latest.json"
        ],
        "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENENDMyOThCRjg1RURDQzQKUldURTNGNzRpeWxEemRlNzhvbW0yL09JMURZejFodW82QnVOMEMyRGhlb0l1andSTERhV2Uxci8K"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}